# ===== 필수 =====
# Google Generative AI API 키 (https://aistudio.google.com)
# 데일리 브리핑 + 주간 AI 단신 생성기(/weekly-flash) 공통 사용. 서버에서만 사용됨.
GEMINI_API_KEY=your_gemini_api_key

# ===== 주간 AI 단신 생성기 (/weekly-flash) =====
# LLM 모델을 env 로 분리. 비워두면 Gemini Pro(grounding 지원) 기본값 사용.
# 웹 검색(grounding)을 지원하는 모델을 지정할 것. 예) gemini-3.1-pro-preview
WEEKLY_FLASH_MODEL=gemini-3.1-pro-preview

# ===== 뉴스 수집 (데일리 브리핑용, 선택) =====
BRAVE_SEARCH_API_KEY=your_brave_api_key
TAVILY_API_KEY=your_tavily_api_key

# ===== 데이터 저장소 (데일리 브리핑용) =====
# 로컬 개발은 파일시스템(data/), 프로덕션은 Vercel KV/Redis 자동 감지
REDIS_URL=
REDIS_PREFIX=

# ===== 스케줄러/크론 보안 (선택) =====
CRON_SECRET=
