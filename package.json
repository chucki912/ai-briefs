    "@types/uuid": "^10.0.0",
    "@vercel/functions": "^3.4.0",
    "@vercel/kv": "^3.0.0",
    "date-fns": "^4.1.0",
    "jsdom": "^22.1.0",
    "linkedom": "^0.18.12",
    "next": "16.1.6",
    "node-cron": "^4.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "redis": "^5.10.0",
    "rss-parser": "^3.13.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
