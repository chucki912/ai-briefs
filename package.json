{
  "name": "ai-daily-brief",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate": "curl -X POST http://localhost:3000/api/generate",
    "scheduler": "npx tsx scripts/scheduler.ts",
    "check:gemini": "npx tsx scripts/check-gemini-models.ts",
    "test:key-insight": "npx tsx scripts/test-key-insight.ts && npx tsx scripts/test-key-insight-regen.ts && npx tsx scripts/test-key-insight-metrics.ts && npx tsx scripts/test-structured-checks.ts",
    "test:triangulation": "npx tsx src/lib/__tests__/validate-triangulation.test.ts",
    "test:render-b": "npx tsx src/lib/__tests__/render-deep-dive-b.test.ts",
    "test:content-gate": "npx tsx src/lib/__tests__/validate-deep-dive.test.ts",
    "test:deep-dive-domain": "npx tsx src/lib/__tests__/deep-dive-domain.test.ts",
    "test:thread-index": "npx tsx src/lib/__tests__/thread-index.test.ts",
    "test:weekly": "npx tsx src/lib/__tests__/thread-index.test.ts && npx tsx src/lib/__tests__/weekly-gate.test.ts && npx tsx src/lib/__tests__/weekly-clustering.test.ts",
    "backfill:thread-index": "npx tsx scripts/backfill-thread-index.ts",
    "regenerate:golden": "npx tsx scripts/regenerate-golden.ts",
    "eval:key-insight": "npx tsx scripts/evaluate-key-insight.ts",
    "eval:key-insight-negative": "npx tsx scripts/negative-control-key-insight.ts",
    "metrics:key-insight": "npx tsx scripts/key-insight-metrics.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mozilla/readability": "^0.6.0",
